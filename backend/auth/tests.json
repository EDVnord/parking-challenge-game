{
  "tests": [
    {
      "name": "Register new player",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "TestKing777", "emoji": "😎", "password": "test1234"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Duplicate nick rejected",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "TestKing777", "emoji": "😎", "password": "test1234"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Этот ник уже занят. Выбери другой!"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login correct password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "name": "TestKing777", "password": "test1234"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "name": "TestKing777", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неверный пароль"},
      "bodyMatcher": "partial"
    }
  ]
}